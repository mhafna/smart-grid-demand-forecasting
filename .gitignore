# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and local secrets
.env
.env.*

# Build and packaging output
build/
dist/
*.egg-info/

# Test and coverage output
.pytest_cache/
.coverage
htmlcov/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# IDE and editor files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Local data, model, and result artifacts
data/raw/*
data/processed/*
models/*
results/*
screenshots/*

# Keep folder placeholders tracked
!data/raw/README.md
!data/processed/README.md
!models/README.md
!results/README.md
!screenshots/README.md
